SELECT w1.id
-- We want the id of the day where temperature increased

FROM Weather w1
JOIN Weather w2
-- Join the Weather table with itself
-- w1 = current day
-- w2 = previous day

ON DATEDIFF(w1.recordDate, w2.recordDate) = 1
-- Check if the difference between dates is exactly 1 day
-- Meaning w2 is yesterday of w1

WHERE w1.temperature > w2.temperature;
-- Current day's temperature must be greater than yesterday's temperature